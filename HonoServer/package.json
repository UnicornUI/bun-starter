{
  "name": "hono-server",
  "module": "src/cli/index.ts",
  "type": "module",
  "bin": {
    "hono-server": "src/cli/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts serve",
    "build": "bun build src/index.ts --target=bun --outfile=dist/index.js",
    "build:exe": "bun build src/index.ts --compile --outfile=dist/hono-server",
    "start": "bun run src/index.ts serve"
  },
  "dependencies": {
    "@effect/language-service": "^0.84.3",
    "@effect/platform-node": "4.0.0-beta.46",
    "@hono/standard-validator": "^0.2.2",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "0.4.2",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "chalk": "^4.1.2",
    "drizzle-orm": "^0.29.5",
    "effect": "4.0.0-beta.46",
    "hono": "^4.12.14",
    "hono-openapi": "1.3.0",
    "yargonaut": "^1.1.4",
    "yargs": "^17.7.2",
    "zod": "4.1.8",
    "zod-openapi": "5.4.6"
  },
  "devDependencies": {
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.12",
    "@types/yargs": "^17.0.35",
    "bun-types": "latest",
    "drizzle-kit": "^0.20.18"
  }
}
